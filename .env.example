###############################################
# HRMS - ENVIRONMENT CONFIGURATION
#
# Copy this file to .env and fill in your values
# OR use: php artisan env:switch local|cloud
#
# LOCAL:  Uses XAMPP MySQL (127.0.0.1, root, no password)
# CLOUD:  Uses remote MySQL with SSL, HTTPS, secure cookies
###############################################

APP_NAME='HRM'
APP_ENV=local                          # local | production
APP_KEY=                               # Run: php artisan key:generate
APP_DEBUG=true                         # true (local) | false (production)
APP_LOG_LEVEL=debug                    # debug (local) | error (production)
APP_URL=http://localhost/hrms          # http://localhost/hrms | https://your-domain.com

# ─── Database ────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                      # 127.0.0.1 (local) | cloud-db-host (production)
DB_PORT=3306
DB_DATABASE=hrms                       # hrms (local) | hrms_production (production)
DB_USERNAME=root                       # root (local) | hrms_user (production)
DB_PASSWORD=                           # empty (local) | secure_password (production)
# MYSQL_ATTR_SSL_CA=                   # Uncomment for cloud SSL connection

# ─── Session & Cache ────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_PATH=/hrms                     # /hrms (local) | / (production)
SESSION_SECURE_COOKIE=false            # false (local) | true (production)
SESSION_SAME_SITE=lax
QUEUE_DRIVER=sync

# ─── Redis ───────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io             # smtp.mailtrap.io (local) | smtp.gmail.com (production)
MAIL_PORT=2525                         # 2525 (local) | 587 (production)
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null                   # null (local) | tls (production)
# MAIL_FROM_ADDRESS=noreply@your-domain.com
# MAIL_FROM_NAME='HRM System'

# ─── Pusher ──────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=

# ─── DeepFace (Face Recognition) ────────────
DEEPFACE_ENABLED=false
DEEPFACE_PYTHON=python                 # python (Windows) | python3 (Linux)
DEEPFACE_SCRIPT=scripts/deepface_verify.py
DEEPFACE_TIMEOUT=120
DEEPFACE_MODEL=Facenet512
DEEPFACE_DETECTOR=opencv
DEEPFACE_FALLBACK_OPENAI=true

# ─── OpenAI API ──────────────────────────────
OPENAI_API_KEY=

# ─── Cloud Only (uncomment for production) ───
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-south-1
# AWS_BUCKET=
# FORCE_HTTPS=true
